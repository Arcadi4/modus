{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "harness-runtime",
  "version": "0.0.0",
  "description": "Runnable OpenCode plugin scaffold for harness",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --project tsconfig.check.json --noEmit",
    "lint": "git ls-files -z --cached --others --exclude-standard 'src/**/*.ts' 'scripts/**/*.ts' | xargs -0 oxlint",
    "lint:fix": "git ls-files -z --cached --others --exclude-standard 'src/**/*.ts' 'scripts/**/*.ts' | xargs -0 oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target bun --format esm && bun build src/server.ts --outdir dist --target bun --format esm && bun build src/tui.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "dev:opencode": "bun ./scripts/dev-opencode.ts",
    "dev:opencode:check": "bun ./scripts/dev-opencode.ts --run 'verification ping'"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "bun": "^1.3.13",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}