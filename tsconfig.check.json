{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "rootDir": ".",
    "types": [
      "bun",
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.fixture.ts"
  ]
}